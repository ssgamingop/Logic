{
  "manifest_version": 3,
  "name": "ITM Crackit Study Helper",
  "version": "2.0.0",
  "description": "Auto-reads questions from any page (even selection-blocked apps), gets AI answers, saves for revision. Built for ITM Crackit students.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://crackit.itmgroup.online/*",
    "https://text.pollinations.ai/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://crackit.itmgroup.online/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
