{
  "name": "crackit-desktop",
  "version": "1.0.0",
  "description": "Desktop app hidden from screen recording",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.crackit.studyhelper",
    "productName": "Crackit Helper",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "tesseract.js": "^7.0.0",
    "ws": "^8.20.1"
  }
}
